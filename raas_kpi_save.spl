`comment("--- 이탈율 월간: 이탈사용자수 / 전월 MAU × 100 ---")`
| append maxout=200000 [
    | inputlookup program_churnuser_funnel_mon.csv
    | where TYPE="ALL" AND PERIOD="1M"
    | eval prev_DATE=strftime(relative_time(strptime(DATE,"%Y/%m/%d"),"-1mon"),"%Y/%m/%d")
    | join type=left prev_DATE [
        | inputlookup program_user_funnel_mon.csv
        | where TYPE="ALL" AND PERIOD="1M"
        | rename DATE AS prev_DATE,
            T00 AS prev_T00, F00 AS prev_F00, L00 AS prev_L00,
            G00 AS prev_G00, P00 AS prev_P00,
            F01 AS prev_F01, F02 AS prev_F02, F03 AS prev_F03, F04 AS prev_F04,
            F05 AS prev_F05, F06 AS prev_F06, F07 AS prev_F07, F08 AS prev_F08,
            F09 AS prev_F09, F10 AS prev_F10, F11 AS prev_F11, F12 AS prev_F12, F13 AS prev_F13,
            L01 AS prev_L01, L02 AS prev_L02, L03 AS prev_L03, L04 AS prev_L04,
            L05 AS prev_L05, L06 AS prev_L06, L07 AS prev_L07, L08 AS prev_L08,
            L09 AS prev_L09, L10 AS prev_L10, L11 AS prev_L11, L12 AS prev_L12,
            L13 AS prev_L13, L14 AS prev_L14, L15 AS prev_L15,
            M05 AS prev_M05, M07 AS prev_M07, M10 AS prev_M10, M11 AS prev_M11
    ]
    | eval
        T00=if(prev_T00>0,round(T00/prev_T00*100,1),null()),
        F00=if(prev_F00>0,round(F00/prev_F00*100,1),null()),
        L00=if(prev_L00>0,round(L00/prev_L00*100,1),null()),
        G00=if(prev_G00>0,round(G00/prev_G00*100,1),null()),
        P00=if(prev_P00>0,round(P00/prev_P00*100,1),null()),
        F01=if(prev_F01>0,round(F01/prev_F01*100,1),null()),
        F02=if(prev_F02>0,round(F02/prev_F02*100,1),null()),
        F03=if(prev_F03>0,round(F03/prev_F03*100,1),null()),
        F04=if(prev_F04>0,round(F04/prev_F04*100,1),null()),
        F05=if(prev_F05>0,round(F05/prev_F05*100,1),null()),
        F06=if(prev_F06>0,round(F06/prev_F06*100,1),null()),
        F07=if(prev_F07>0,round(F07/prev_F07*100,1),null()),
        F08=if(prev_F08>0,round(F08/prev_F08*100,1),null()),
        F09=if(prev_F09>0,round(F09/prev_F09*100,1),null()),
        F10=if(prev_F10>0,round(F10/prev_F10*100,1),null()),
        F11=if(prev_F11>0,round(F11/prev_F11*100,1),null()),
        F12=if(prev_F12>0,round(F12/prev_F12*100,1),null()),
        F13=if(prev_F13>0,round(F13/prev_F13*100,1),null()),
        L01=if(prev_L01>0,round(L01/prev_L01*100,1),null()),
        L02=if(prev_L02>0,round(L02/prev_L02*100,1),null()),
        L03=if(prev_L03>0,round(L03/prev_L03*100,1),null()),
        L04=if(prev_L04>0,round(L04/prev_L04*100,1),null()),
        L05=if(prev_L05>0,round(L05/prev_L05*100,1),null()),
        L06=if(prev_L06>0,round(L06/prev_L06*100,1),null()),
        L07=if(prev_L07>0,round(L07/prev_L07*100,1),null()),
        L08=if(prev_L08>0,round(L08/prev_L08*100,1),null()),
        L09=if(prev_L09>0,round(L09/prev_L09*100,1),null()),
        L10=if(prev_L10>0,round(L10/prev_L10*100,1),null()),
        L11=if(prev_L11>0,round(L11/prev_L11*100,1),null()),
        L12=if(prev_L12>0,round(L12/prev_L12*100,1),null()),
        L13=if(prev_L13>0,round(L13/prev_L13*100,1),null()),
        L14=if(prev_L14>0,round(L14/prev_L14*100,1),null()),
        L15=if(prev_L15>0,round(L15/prev_L15*100,1),null()),
        M05=if(prev_M05>0,round(M05/prev_M05*100,1),null()),
        M07=if(prev_M07>0,round(M07/prev_M07*100,1),null()),
        M10=if(prev_M10>0,round(M10/prev_M10*100,1),null()),
        M11=if(prev_M11>0,round(M11/prev_M11*100,1),null())
    | fields - prev_*
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE metric_value
    | eval PGM_CODE=upper(PGM_CODE), metric_type="churn_mon",
           metric_value=tonumber(metric_value), DATE_MON=DATE,
           _time=strptime(DATE,"%Y/%m/%d"), today_value=metric_value
]

