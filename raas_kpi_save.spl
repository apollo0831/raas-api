             RR_F01 as F01, RR_F02 as F02, RR_F03 as F03, RR_F04 as F04, RR_F05 as F05,
             RR_F06 as F06, RR_F07 as F07, RR_F08 as F08, RR_F09 as F09, RR_F10 as F10,
             RR_F11 as F11, RR_F12 as F12, RR_F13 as F13,
             RR_L01 as L01, RR_L02 as L02, RR_L03 as L03, RR_L04 as L04, RR_L05 as L05,
             RR_L06 as L06, RR_L07 as L07, RR_L08 as L08, RR_L09 as L09, RR_L10 as L10,
             RR_L11 as L11, RR_L12 as L12, RR_L13 as L13, RR_L14 as L14, RR_L15 as L15,
             RR_M05 as M05, RR_M07 as M07, RR_M10 as M10, RR_M11 as M11
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE metric_value
    | eval PGM_CODE=upper(PGM_CODE), metric_type="new_d7_ret_day",
           metric_value=tonumber(metric_value),
