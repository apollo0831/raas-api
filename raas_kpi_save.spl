`comment("--- 참여율 일간: 참여사용자수 / DAU × 100 ---")`
| append maxout=200000 [
    | inputlookup program_user_engage_day.csv
    | search TYPE=TOTAL_USER
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE eng_val
    | eval eng_val=coalesce(tonumber(eng_val), 0)
    | join type=left max=1 DATE PGM_CODE [
        | inputlookup program_user_funnel_day.csv
        | search TYPE=ALL
        | fields DATE T00 F00 L00 G00 P00 F* L* M*
        | untable DATE PGM_CODE dau_val
        | eval dau_val=coalesce(tonumber(dau_val), 0)
    ]
    | eval metric_value=if(dau_val>0, round(eng_val/dau_val*100,1), 0)
    | eval PGM_CODE=upper(PGM_CODE)
    | xyseries DATE PGM_CODE metric_value
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE metric_value
    | eval PGM_CODE=upper(PGM_CODE), metric_type="engage_day",
           metric_value=tonumber(metric_value),
           _time=strptime(DATE,"%Y/%m/%d"), today_value=metric_value
]

`comment("--- 습관형성률 일간: 3D7D_1M / ALL × 100, +6일 시프트 ---")`
| append maxout=200000 [
    | inputlookup program_newuser_funnel_day.csv
    | search TYPE=3D7D_1M
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE num_val
    | eval num_val=coalesce(tonumber(num_val), 0)
    | join type=left max=1 DATE PGM_CODE [
        | inputlookup program_newuser_funnel_day.csv
        | search TYPE=ALL
        | fields DATE T00 F00 L00 G00 P00 F* L* M*
        | untable DATE PGM_CODE dau_val
        | eval dau_val=coalesce(tonumber(dau_val), 0)
    ]
    | eval metric_value=if(dau_val>0, round(num_val/dau_val*100,1), 0)
    | eval PGM_CODE=upper(PGM_CODE)
    | xyseries DATE PGM_CODE metric_value
    | eval _time=strptime(DATE,"%Y/%m/%d")
    | eval DATE=strftime(relative_time(_time,"+6d"),"%Y/%m/%d")
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE metric_value
    | eval PGM_CODE=upper(PGM_CODE), metric_type="habit_day",
           metric_value=tonumber(metric_value),
           _time=strptime(DATE,"%Y/%m/%d"), today_value=metric_value
]

