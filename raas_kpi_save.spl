| inputlookup program_user_funnel_day.csv
`comment("================================================================")`
`comment("raas_kpi_latest.csv 저장용 쿼리 — 일간 + 주간 + 월간 통합")`
`comment("스케줄: 매일 07:10 (일배치 완료 후)")`
`comment("결과: PGM_CODE별 1행에 일간/주간/월간 지표 + 편성정보 포함")`
`comment("metric_type 명명 규칙: 모두 소문자 + _day / _week / _mon suffix 통일")`
`comment("DATE     : 소스 룩업의 일간 기준 날짜 (전일)")`
`comment("DATE_WEEK: 소스 룩업의 주간 기준 날짜 (전주 월요일)")`
`comment("DATE_MON : 소스 룩업의 월간 기준 날짜 (전월 1일)")`
`comment("================================================================")`

`comment("================================================================")`
`comment("=== [1] 일간 지표 블록 ===")`
`comment("================================================================")`
| search TYPE=ALL AND PERIOD=1D
| fields DATE T00 F00 L00 G00 P00 F* L* M*
| untable DATE PGM_CODE metric_value
| eval PGM_CODE=upper(PGM_CODE), metric_type="dau_day",
       metric_value=tonumber(metric_value),
       _time=strptime(DATE,"%Y/%m/%d"), today_value=metric_value

| append maxout=200000 [
    | inputlookup program_user_funnel_day.csv
    | search TYPE=ALL AND PERIOD=7D
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE metric_value
    | eval PGM_CODE=upper(PGM_CODE), metric_type="wau_day",
           metric_value=tonumber(metric_value),
           _time=strptime(DATE,"%Y/%m/%d"), today_value=metric_value
]

| append maxout=200000 [
    | inputlookup program_user_funnel_day.csv
    | search TYPE=ALL AND PERIOD=30D
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE metric_value
    | eval PGM_CODE=upper(PGM_CODE), metric_type="mau_day",
           metric_value=tonumber(metric_value),
           _time=strptime(DATE,"%Y/%m/%d"), today_value=metric_value
]

| append maxout=200000 [
    | inputlookup program_newuser_funnel_day.csv
    | search TYPE=ALL AND PERIOD=1D
    | fields DATE T00 F00 L00 G00 P00 F* L* M*
    | untable DATE PGM_CODE metric_value
    | eval PGM_CODE=upper(PGM_CODE), metric_type="new_day",
           metric_value=tonumber(metric_value),
